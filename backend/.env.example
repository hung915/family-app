# Copy to .env and fill in real values. Never commit .env.
ENV=local

# PostgreSQL — use asyncpg driver scheme
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/family_app

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ORIGINS=["http://localhost:5173"]

# ── Auth ──────────────────────────────────────────────────────────────────────
# Both secrets: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me
MAGIC_LINK_SECRET=change-me

# Resend (https://resend.com) — create an API key and verify a sending domain.
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=Family App <noreply@yourdomain.com>

# Base URL of this API — used to build the magic-link callback URL.
# Local: http://localhost:8000  |  Production: https://api.yourdomain.com
API_BASE_URL=http://localhost:8000

# Where to redirect after a successful login.
FRONTEND_URL=http://localhost:5173
